generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // Используется для работы приложения
  directUrl = env("DIRECT_URL")   // Используется для миграций
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  bio       String?
  avatarUrl String?
  slug      String   @unique // Уникальная ссылка: nowfolio.com/u/ivan
  
  // Здесь будем хранить токены и данные (YouTube, Instagram)
  socialAccounts Json? 
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}