generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  name             String?
  bio              String?
  avatarUrl        String?
  slug             String   @unique
  socialAccounts   Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  isPro            Boolean  @default(false)
  stripeCustomerID String?
}
